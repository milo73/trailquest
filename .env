# Copy to .env and adjust. All settings are optional (sensible defaults apply).
TRAILQUEST_ENVIRONMENT=development

# LLM provider abstraction (PRD §8.4). "stub" needs no API key; switch to a real
# provider once implemented. Default model targets the latest Claude model.

TRAILQUEST_POI_SOURCE=live
TRAILQUEST_LLM_PROVIDER=claude_cli
TRAILQUEST_LLM_MODEL=claude-sonnet-4-6

# Shared outbound timeout (s). The claude_cli/ollama providers use 4x this, so
# 120 gives generation ~8 min of headroom (CLI startup + model latency).
TRAILQUEST_HTTP_TIMEOUT=120

# TRAILQUEST_LLM_PROVIDER=stub
# TRAILQUEST_LLM_MODEL=claude-sonnet-4-7

# First launch city (PRD §19).
TRAILQUEST_DEFAULT_CITY=Haarlem
